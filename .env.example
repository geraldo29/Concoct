# Concoct environment variables
# Copy this file to `.env.local` and fill in your values.
# `.env.local` is gitignored.

# ─── Google Gemini (optional — falls back to mock if missing) ───
# https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=

# ─── AWS backend (provisioned by `cd infra && npm run deploy`) ───
# Copy these from the CloudFormation outputs after `cdk deploy`.
VITE_AWS_REGION=us-east-1
VITE_AWS_USER_POOL_ID=
VITE_AWS_USER_POOL_CLIENT_ID=
VITE_AWS_API_URL=
