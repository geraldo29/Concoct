# Concoct environment variables
# Copy this file to `.env.local` and fill in your values.
# `.env.local` is gitignored by default in Vite projects.

# Google Gemini API key (https://aistudio.google.com/apikey)
# NOTE: Vite exposes any VITE_-prefixed var to the browser bundle.
# In production, restrict this key to your deployed domain in Google AI Studio.
VITE_GEMINI_API_KEY=
